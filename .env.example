# NEXUS - Global Intelligence Platform
# Copy this to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000

# Optional: Cesium Ion Token for terrain + high-res imagery
# Get free token at: https://cesium.com/ion/signup
CESIUM_ION_TOKEN=

# Optional: OpenSky Network credentials for higher rate limits
# Get free account at: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Optional: Space Devs API key for higher rate limits
# Get free key at: https://ll.thespacedevs.com/
SPACEDEVS_TOKEN=

# Cache TTLs (seconds)
SATELLITE_TLE_TTL=7200
FLIGHT_TTL=15
SEISMIC_TTL=300
LAUNCH_TTL=3600
ISS_TTL=5
